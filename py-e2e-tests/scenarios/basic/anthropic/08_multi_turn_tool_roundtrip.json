{
  "name": "多轮对话 — 工具调用后继续",
  "endpoint": "anthropic",
  "category": "basic",
  "models": ["deepseek-default", "deepseek-expert"],
  "request": {
    "system": "你是一个天气助手，使用 get_weather 工具查询天气。每次调用后，根据结果回答用户。",
    "messages": [
      {"role": "user", "content": "北京今天天气怎么样？"},
      {"role": "assistant", "content": [{"type": "tool_use", "id": "toolu_abc123", "name": "get_weather", "input": {"city": "北京"}}]},
      {"role": "user", "content": [{"type": "tool_result", "tool_use_id": "toolu_abc123", "content": "北京今天晴，25°C"}]},
      {"role": "assistant", "content": [{"type": "text", "text": "不客气，北京今天晴，25°C，适合出门活动。祝您愉快！"}]},
      {"role": "user", "content": "那上海呢？"}
    ],
    "max_tokens": 4096,
    "tools": [
      {
        "type": "custom",
        "name": "get_weather",
        "description": "获取指定城市的天气信息",
        "input_schema": {
          "type": "object",
          "properties": {
            "city": {"type": "string", "description": "城市名称"}
          },
          "required": ["city"]
        }
      }
    ],
    "tool_choice": {"type": "auto"},
    "stream": false
  },
  "checks": {
    "has_tool_use": true
  }
}
